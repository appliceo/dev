# Copy to config/clever.local.env (gitignored, chmod 600 recommended).
# Or run:  bash bin/clever-sync.sh --bootstrap   (auto-pulls current values from Clever)
#
# These are PRODUCTION secrets — different from config/local.env (which holds dev secrets).
# Required for `bin/clever-sync.sh --apply` to push complete env.

# JWT_SECRET=<prod-only secret, must match between api app and any consumer>
# V1_AUTH_API_KEY=<prod-only V1 bridge shared key>
# PHP_BASIC_AUTH=<base64(user:password) for dev.appliceo.com .htaccess>

# DocuSign (production app)
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_WEBHOOK_SECRET=

# DocuSign private key — file path (NOT inline). Script reads the PEM, base64-encodes it,
# and pushes as DOCUSIGN_PRIVATE_KEY at sync time. Default points at api/keys/docusign_private.key
# (the same PEM the local api uses). If your prod DocuSign key differs from the local one,
# point this at the prod PEM.
# DOCUSIGN_PRIVATE_KEY_FILE=../api/keys/docusign_private.key
