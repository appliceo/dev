# Profile: clever
# Targets the Clever Cloud apps (api + docuceo). Only used by bin/clever-sync.sh,
# never sourced by configure.sh for local dev. Values mirror what already runs in prod.
NODE_ENV=production
HOST=0.0.0.0
PORT=8080

# Clever Cloud Node runtime
CC_NODE_VERSION=22
CC_NODE_BUILD_TOOL=npm
CC_NODE_DEV_DEPENDENCIES=install
CC_PRE_RUN_HOOK="npm run build"
CC_POST_BUILD_HOOK="npm run build"

# Frontend / proxy URLs
PUBLIC_API_URL=https://api-dev.appliceo.com
PUBLIC_PHP_API_URL=https://dev.appliceo.com
PHP_API_URL=https://dev.appliceo.com

# api specifics
SIGNING_PROVIDER=docusign
SWAGGER_HOST=api-dev.appliceo.com
CORS_ORIGIN="https://dev.appliceo.com, https://docuceo.com"
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
