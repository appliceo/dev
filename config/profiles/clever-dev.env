# Profile: clever-dev
# Targets the Clever Cloud DEV apps (appliceo-api-dev + appliceo-docuceo-dev).
# Only used by bin/clever-sync.sh --env dev. Never sourced by configure.sh.
#
# Secrets (JWT, DocuSign, Stripe, Mailgun) shared with prod for now — see
# config/clever.local.env. They'll split per-env on rotation day.
NODE_ENV=production
HOST=0.0.0.0
PORT=8080

# Clever Cloud Node runtime
CC_NODE_VERSION=22
CC_NODE_BUILD_TOOL=npm
CC_NODE_DEV_DEPENDENCIES=install
# api uses PRE_RUN_HOOK to chain build → migrate (Drizzle migrator is idempotent + locked).
# docuceo uses POST_BUILD_HOOK for its build step (no migrations there).
CC_PRE_RUN_HOOK="npm run build && npm run migrate"
CC_POST_BUILD_HOOK="npm run build"

# Frontend / proxy URLs — DEV variants
PUBLIC_API_URL=https://api-dev.appliceo.com
PUBLIC_API_BROWSER_URL=https://api-dev.appliceo.com
PUBLIC_PHP_API_URL=https://dev.appliceo.com
PHP_API_URL=https://dev.appliceo.com

# api specifics
SIGNING_PROVIDER=docusign
# Swagger UI: ON in dev for debugging. Public-facing URL is OK on dev CC since
# the host is Basic-Auth gated by docuceo's DEV_BASIC_AUTH layer.
SWAGGER_UI_ENABLED=true
SWAGGER_HOST=api-dev.appliceo.com
CORS_ORIGIN="https://dev.docuceo.com"
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi

# Mailer — same provider + keys as prod for now (see clever.local.env).
MAILER_DRIVER=mailgun
MAILGUN_API_KEY=__set_in_clever__
MAILGUN_DOMAIN=mg.appliceo.com
MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3
MAIL_FROM="Appliceo dev <noreply@appliceo.com>"
MAIL_SUPPORT_TO=support@appliceo.com
APP_NAME=Appliceo
PUBLIC_APP_URL=https://dev.docuceo.com
PUBLIC_LEASE_SIGNING_ENABLED=true

# Dev-host auth guard for docuceo (dev.docuceo.com). Base64 of `user:password`,
# blocks search engines + casual visitors. Real value set via Clever Cloud env panel.
DEV_BASIC_AUTH=__set_in_clever__
