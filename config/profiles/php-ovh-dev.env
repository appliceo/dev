# Profile: php-ovh-dev
# Rendered by `bin/php-deploy-config.sh dev` → uploaded to dev.appliceo.com (OVH).
# Sourced AFTER config/defaults.env and AFTER secrets.dev.sops.yaml — so
# MYSQL_* below can reference OVH_DEV_DB_* keys that live in dev SOPS.
#
# Only PHP-render keys live here. Runtime configs for api / docuceo on
# Clever Cloud belong in clever-*.env profiles.

# OVH MySQL host (managed cloud DB, port baked into the hostname).
DB_HOST=zm44529-001.eu.clouddb.ovh.net:35650
# DB credentials — sourced from SOPS so they never leave encrypted storage.
# `:?` form fails loud on BOTH unset AND empty — empty placeholders ship in
# dev SOPS so `secret.sh edit dev` is the right next step before any render.
MYSQL_DATABASE=${OVH_DEV_DB_NAME:?empty/missing in dev SOPS — fill via bin/secret.sh edit dev}
MYSQL_USER=${OVH_DEV_DB_USER:?empty/missing in dev SOPS — fill via bin/secret.sh edit dev}
MYSQL_PASSWORD=${OVH_DEV_DB_PASSWORD:?empty/missing in dev SOPS — fill via bin/secret.sh edit dev}

# Filesystem paths on the OVH mutualisé host.
ABS_PATH_SITE=/home/appliceopj/dev
ABS_PATH_GESTION=/home/appliceopj/dev/gestion

# Public URL — dev.appliceo.com behind Basic Auth (.htaccess).
APP_PROTOCOL=https://
APP_DOMAIN=dev.appliceo.com
APP_PORT=443

# DEV_AUTO_LOGIN: OFF on remote dev. The Basic-Auth gate is the only
# protection; auto-login on a public host would be a backdoor.
DEV_AUTO_LOGIN=false
DEV_AUTO_LOGIN_USER_ID=0

# Stripe — live keys flow from SOPS, but OVH dev should hit real Stripe.
STRIPE_MOCK_MODE=false
