# Profile: full-local
# Everything runs in containers. URL targets are docker-network DNS names.
PHP_API_URL=http://apache:80
PUBLIC_PHP_API_URL=http://apache:80
PUBLIC_API_URL=http://api:5001
# Browser-facing api URL — host port mapping (browser can't resolve docker DNS).
PUBLIC_API_BROWSER_URL=http://localhost:5001
# Wide-open in dev — security in a local container is moot, and `*` avoids
# the localhost vs 127.0.0.1 vs LAN-IP edge cases.
CORS_ORIGIN=*
APP_PROTOCOL=https://
APP_DOMAIN=localhost
APP_PORT=8443
