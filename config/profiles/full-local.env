# Profile: full-local
# Everything runs in containers. URL targets are docker-network DNS names.
PHP_API_URL=http://apache:80
PUBLIC_PHP_API_URL=http://apache:80
PUBLIC_API_URL=http://api:5001
# Browser-facing api URL — host port mapping (browser can't resolve docker DNS).
PUBLIC_API_BROWSER_URL=http://localhost:5001
# Wide-open in dev — security in a local container is moot, and `*` avoids
# the localhost vs 127.0.0.1 vs LAN-IP edge cases.
CORS_ORIGIN=*
APP_PROTOCOL=https://
APP_DOMAIN=localhost
APP_PORT=8443

# Mailer — stub in dev (emails captured to logs, never sent)
MAILER_DRIVER=stub
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.appliceo.com
MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3
MAIL_FROM="Appliceo dev <noreply@appliceo.local>"
MAIL_SUPPORT_TO=support@appliceo.local
APP_NAME=Appliceo
# Browser-facing docuceo URL — used by api to build links in transactional emails
PUBLIC_APP_URL=http://localhost:4321

# Feature flag: show "Envoyer pour signature" button in the lease editor.
PUBLIC_LEASE_SIGNING_ENABLED=true

# Dev-host auth guard — empty for local (localhost bypasses the guard).
# Declared here for key parity with clever-dev.
DEV_BASIC_AUTH=

# api runtime — values match clever-* profiles for consistent dev behaviour.
# Background workers (envelope-worker, payment-reconciler, envelope-status-poller)
# skip when NODE_ENV=test; everything else runs.
NODE_ENV=development
PORT=5001
# Provider lock — kept as env so we can swap later without code change.
SIGNING_PROVIDER=docusign
# JWT lifetimes — same as clever-dev. Local stays close to prod to surface
# token-refresh edge cases naturally.
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
# Swagger UI: on in dev, off in prod. The plugin gates registration on
# SWAGGER_UI_ENABLED='true' (api/src/plugins/swagger.ts:7); SWAGGER_HOST
# controls the OpenAPI `servers:` block, only used when UI is enabled.
SWAGGER_UI_ENABLED=true
SWAGGER_HOST=
# DocuSign sandbox base path (same value used by clever-* profiles).
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
