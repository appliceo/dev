# Profile: full-local
# Everything runs in containers. URL targets are docker-network DNS names.
PHP_API_URL=http://apache:80
PUBLIC_PHP_API_URL=http://apache:80
PUBLIC_API_URL=http://api:5001
# Browser-facing api URL — host port mapping (browser can't resolve docker DNS).
PUBLIC_API_BROWSER_URL=http://localhost:5001
# Wide-open in dev — security in a local container is moot, and `*` avoids
# the localhost vs 127.0.0.1 vs LAN-IP edge cases.
CORS_ORIGIN=*
APP_PROTOCOL=https://
APP_DOMAIN=localhost
APP_PORT=8443

# Mailer — stub in dev (emails captured to logs, never sent)
MAILER_DRIVER=stub
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.appliceo.com
MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3
MAIL_FROM="Appliceo dev <noreply@appliceo.local>"
MAIL_SUPPORT_TO=support@appliceo.local
APP_NAME=Appliceo
# Browser-facing docuceo URL — used by api to build links in transactional emails
PUBLIC_APP_URL=http://localhost:4321
