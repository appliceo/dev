# Profile: staging
# Frontends point entirely at remote dev backends. Generates a gestion/config.php
# whose ABS_URL etc. reflect the staging domain.
PHP_API_URL=https://dev.appliceo.com
PUBLIC_PHP_API_URL=https://dev.appliceo.com
PUBLIC_API_URL=https://api.appliceo.com
APP_PROTOCOL=https://
APP_DOMAIN=dev.appliceo.com
APP_PORT=443

# Mailer — staging profile drives docuceo SSR + frontends only; remote api owns its own mailer config.
MAILER_DRIVER=stub
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.appliceo.com
MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3
MAIL_FROM="Appliceo <noreply@appliceo.com>"
MAIL_SUPPORT_TO=support@appliceo.com
APP_NAME=Appliceo
PUBLIC_APP_URL=https://docuceo.com
