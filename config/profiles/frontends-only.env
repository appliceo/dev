# Profile: frontends-only
# Local docuceo against remote dev api/php (no local containers needed for
# those — comment them out in compose if desired).
# PHP_BASIC_AUTH must be set in local.env for dev.appliceo.com.
PHP_API_URL=https://dev.appliceo.com
PUBLIC_PHP_API_URL=https://dev.appliceo.com
PUBLIC_API_URL=https://api.appliceo.com
APP_PROTOCOL=https://
APP_DOMAIN=localhost
APP_PORT=8443

# Mailer — stub locally; the remote api has its own production mailer config.
MAILER_DRIVER=stub
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.appliceo.com
MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3
MAIL_FROM="Appliceo dev <noreply@appliceo.local>"
MAIL_SUPPORT_TO=support@appliceo.local
APP_NAME=Appliceo
PUBLIC_APP_URL=http://localhost:4321
