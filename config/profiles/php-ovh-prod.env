# Profile: php-ovh-prod
# Rendered by `bin/php-deploy-config.sh prod` → uploaded to appliceo.com (OVH).
# Sourced AFTER config/defaults.env and AFTER secrets.prod.sops.yaml — so
# MYSQL_* below can reference OVH_PROD_DB_* keys that live in prod SOPS.
#
# FIXME: values below are CLONED from php-ovh-dev and need a manual review
# before first prod render. Replace anything tagged __fill_before_first_prod_render__
# with the real prod-side value (DB host, abs paths). The render script
# refuses to ship if any placeholder survives substitution.

# OVH MySQL host — likely a different addon than dev. Fill in once known.
DB_HOST=__fill_before_first_prod_render__
# DB credentials — sourced from SOPS prod.
# `:?` form fails on BOTH unset AND empty.
MYSQL_DATABASE=${OVH_PROD_DB_NAME:?empty/missing in prod SOPS — fill via bin/secret.sh edit prod}
MYSQL_USER=${OVH_PROD_DB_USER:?empty/missing in prod SOPS — fill via bin/secret.sh edit prod}
MYSQL_PASSWORD=${OVH_PROD_DB_PASSWORD:?empty/missing in prod SOPS — fill via bin/secret.sh edit prod}

# Filesystem paths on the OVH mutualisé host. Prod typically deploys to ~/www.
ABS_PATH_SITE=__fill_before_first_prod_render__
ABS_PATH_GESTION=__fill_before_first_prod_render__

# Public URL — appliceo.com (no Basic Auth, full public site).
APP_PROTOCOL=https://
APP_DOMAIN=appliceo.com
APP_PORT=443

# DEV_AUTO_LOGIN: hard OFF on prod.
DEV_AUTO_LOGIN=false
DEV_AUTO_LOGIN_USER_ID=0

# Stripe — live keys, real charges.
STRIPE_MOCK_MODE=false
