# Baseline values for every profile. Sourced first by bin/configure.sh.
# Override per profile in config/profiles/*.env, or per-machine in config/local.env.
# Real secrets DO NOT belong here — put those in local.env (gitignored).

# Shared dev secrets — safe to commit (rotated per env in prod)
JWT_SECRET=e95dabb55153ff128aa5544e66290aa844e0976bbe754bb3173f943c2f151e4f
V1_AUTH_API_KEY=q_jJKBE03HxV19IkrPMhoUuXus89x-UBMkosaU55UCY

# DB creds — dev-only; same default values for postgres + mysql containers
POSTGRES_DB=appliceo_v2
POSTGRES_USER=appliceo
POSTGRES_PASSWORD=appliceo_dev
MYSQL_DATABASE=appliceo_php
MYSQL_USER=appliceo
MYSQL_PASSWORD=appliceo123
MYSQL_ROOT_PASSWORD=root123

# Ports (host side). Override only if you have local clashes.
PORT_API=5001
PORT_DOCUCEO=4321
PORT_POSTGRES=5432
PORT_MYSQL=3306
PORT_PHP_HTTP=8080
PORT_PHP_HTTPS=8443

# Dev flags
NODE_ENV=development
CHOKIDAR_USEPOLLING=true
DEV_AUTO_LOGIN=true
DEV_AUTO_LOGIN_USER_ID=347

# JWT / auth lifecycle
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Real secrets — empty by default. Fill in local.env when needed.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY_PATH=./keys/docusign_private.key
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_WEBHOOK_SECRET=
SIGNING_PROVIDER=docusign

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MOCK_MODE=true

# HTTP Basic Auth for remote dev backend (https://dev.appliceo.com).
# Generate: printf '%s' 'user:pass' | base64
PHP_BASIC_AUTH=

# docuceo feature flag: shows the "Envoyer pour signature" button in the lease
# editor. Off by default; flip to "true" in config/local.env to enable locally.
PUBLIC_LEASE_SIGNING_ENABLED=false

# Browser-facing api URL — what client islands hit directly via CORS.
# Empty default; profiles set the per-env value (host port locally, public
# URL in prod). The existing PUBLIC_API_URL stays as the SSR-only docker
# internal hostname.
PUBLIC_API_BROWSER_URL=

# api CORS allowlist. Empty/unset → '*' (reflected origin) in api code.
# Profiles set this per env (* in dev, explicit list in prod).
CORS_ORIGIN=
