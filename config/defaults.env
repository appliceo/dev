# Baseline values for every profile. Sourced first by bin/configure.sh.
# Secrets live in config/secrets.dev.sops.yaml (SOPS-encrypted). Per-env
# overrides go in config/profiles/*.env. Real secrets NEVER belong here.

# Rotation slots — `bin/secret.sh rotate <KEY> dev` moves current → previous
# so verifiers accept both during the overlap window. Empty by default; SOPS
# populates them mid-rotation.
JWT_SECRET_PREVIOUS=
V1_AUTH_API_KEY_PREVIOUS=
DOCUSIGN_WEBHOOK_SECRET_PREVIOUS=

# DB creds — dev-only; same default values for postgres + mysql containers
POSTGRES_DB=appliceo_v2
POSTGRES_USER=appliceo
POSTGRES_PASSWORD=appliceo_dev
MYSQL_DATABASE=appliceo_php
MYSQL_USER=appliceo
MYSQL_PASSWORD=appliceo123
MYSQL_ROOT_PASSWORD=root123

# Ports (host side). Override only if you have local clashes.
PORT_API=5001
PORT_DOCUCEO=4321
PORT_POSTGRES=5432
PORT_MYSQL=3306
PORT_PHP_HTTP=8080
PORT_PHP_HTTPS=8443

# Dev flags
NODE_ENV=development
CHOKIDAR_USEPOLLING=true
DEV_AUTO_LOGIN=true
DEV_AUTO_LOGIN_USER_ID=347

# JWT / auth lifecycle
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# DocuSign — non-secret config; the IDs and webhook secret live in SOPS.
DOCUSIGN_PRIVATE_KEY_PATH=./keys/docusign_private.key
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
SIGNING_PROVIDER=docusign

# Stripe — non-secret config. Real keys live in SOPS.
STRIPE_MOCK_MODE=true
STRIPE_API_VERSION=2022-11-15

# Mailgun — non-secret config. API key lives in SOPS.
MAILGUN_DOMAIN=mg.appliceo.com
MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3

# docuceo feature flag — profiles override per env.
PUBLIC_LEASE_SIGNING_ENABLED=false

# Browser-facing api URL + CORS allowlist — profiles set per env.
PUBLIC_API_BROWSER_URL=
CORS_ORIGIN=
