# Copy to config/local.env (gitignored) and fill in only the secrets you need.
# config/local.env is sourced LAST by bin/configure.sh, so values here override
# defaults.env and the active profile.
#
# Examples:
# DOCUSIGN_INTEGRATION_KEY=...
# DOCUSIGN_USER_ID=...
# DOCUSIGN_ACCOUNT_ID=...
# DOCUSIGN_WEBHOOK_SECRET=...
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PHP_BASIC_AUTH=...   # printf '%s' 'user:pass' | base64
