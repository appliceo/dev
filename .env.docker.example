# Compose-only env. Copy to .env at this folder before `docker compose up`.
# Service-specific secrets (DocuSign, JWT, etc.) come from each project's own
# .env (./api/.env, ./docuceo/.env, ./appliceo-php/.env) via env_file in compose.

# --- PHP backend (only needed if pointing at remote dev.appliceo.com) ---
# Base64(user:pass) for dev.appliceo.com .htaccess Basic Auth.
# Leave empty for the local apache container — no Basic Auth needed.
# Generate: printf '%s' 'user:pass' | base64
PHP_BASIC_AUTH=

# --- Postgres (api + future docuceo writes) ---
POSTGRES_DB=appliceo_v2
POSTGRES_USER=appliceo
POSTGRES_PASSWORD=appliceo_dev

# --- MySQL (PHP V1) ---
MYSQL_DATABASE=appliceo_php
MYSQL_USER=appliceo
MYSQL_PASSWORD=appliceo123
MYSQL_ROOT_PASSWORD=root123

# --- HMR polling ---
# true (default): reliable HMR on Windows host with NTFS source. Higher idle CPU.
# false: lower CPU; only works if source is inside WSL2 or on macOS/Linux host.
CHOKIDAR_USEPOLLING=true

# --- Port mappings (host side) ---
# Override only if these clash with something else on your machine.
PORT_DOCUCEO=4321
PORT_API=5001
PORT_POSTGRES=5432
PORT_MYSQL=3306
PORT_PHP_HTTP=8080
PORT_PHP_HTTPS=8443

# --- Override targets (advanced) ---
# Default is to use local containers. Override to point at remote backends.
# PHP_API_URL=https://dev.appliceo.com         # PHP backend target
# PUBLIC_PHP_API_URL=https://dev.appliceo.com  # docuceo proxy target
# V1_PHP_API_URL=https://dev.appliceo.com      # api V1 fallback
