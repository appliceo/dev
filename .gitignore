# Root repo = Appliceo dev stack (Docker compose + scripts).
# Each sub-project below has its own remote and is cloned independently.

# Sub-project repos — never tracked here
/api/
/ui/
/lease-config/
/lease-editor/
/lease-editor-native/
/appliceo-lease-editor-native/
/docuceo/
/EtatDesLieux/
/appliceo-design/
/appliceo-node/
/appliceo-php/
/e2e/
/rapporteur/

# Local nested dev-stack clone used for fresh-clone testing
/dev/

# AI tools
.claude/
.cursor/
.cursorrules
.aider*
.continue/

# Local planning / scratch
.planning/

# Editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Environment — generated by bin/configure.sh from config/templates/.
.env
.env.local
.env.docker

# SOPS — prod secret store stays local-only.
# config/secrets.dev.sops.yaml IS committed (encrypted; safe to share).
/config/secrets.prod.sops.yaml
# Defensive: never commit a plaintext working copy of any secrets file.
/config/secrets.*.yaml.dec
/config/secrets.*.plain.yaml

# Service-account / signing JSONs (Play Store, etc.) — never commit
/keys/

# Node (none expected at root, but defensive)
node_modules/
test-results

# Rendered by bin/configure.sh — contains decrypted secrets; never commit.
docker/php/gestion-config.php
local.env
